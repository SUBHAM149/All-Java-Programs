package com.sub.interface_ex;
import java.util.Scanner;
interface Payment 
{
	public abstract void  processPayment();
	public abstract void applayDiscount();
}

class CreditCardPayment implements Payment
{
	@Override
	public void  processPayment()
	{
		IO.println("Processing Credit Card payment...");
	}
	@Override
	public void applayDiscount()
	{
		IO.println("Applying 10% discount for Credit Card payment");
	}
}

class UPIPayment implements Payment
{
	@Override
    public void processPayment() {
        System.out.println("Processing UPI payment...");
    }

    @Override
    public void applayDiscount() {
        System.out.println("Applying 5% discount for UPI payment");
    }

	
}
class PaymentGateway
{
	public Payment initiatePayment(String paymentType)
	{
		if (paymentType.equalsIgnoreCase("creditcard")) {
            System.out.println("Initiating Credit Card payment");
            return new CreditCardPayment();
        } else if (paymentType.equalsIgnoreCase("upi")) {
            System.out.println("Initiating UPI payment");
            return new UPIPayment();
        } else {
            System.out.println("Invalid payment type selected!");
            return null;
        }

	}
}
public class PaymentGatewayUsingInterface 
{

	public static void main(String[] args) 
	{
		Scanner sc=new Scanner(System.in);
		IO.println("Enter Payment Type [CreditCard / UPI]:");
		String paymentType=sc.nextLine();
		
		PaymentGateway gateway=new PaymentGateway();
		Payment payment=gateway.initiatePayment(paymentType);
		
		if(payment != null)
		{
			payment.processPayment();
			payment.applayDiscount();		
			}
		
		sc.close();
	}
	
}


Assignment 02 
-------------
Develop a Program on Factory Method where method return type is interface.

Coding Requirement :
---------------------
Take a Functional interface Printer which contains a print() method.

Methods :

1) Method Name     : print()
   Parameter       : No Parameter
   Return Type     : void
   Access Modifier : public
   Modifier   : abstract

Take another class PrinterDemo.

1) Method Name     : getPrinter()
   Parameter       : No Parameter
   Return Type     : Printer [Factory Method (Factory Design Pattern)]
   Access Modifier : public
 
   In this method override the print() method of Printer interface, using anonymous inner class WITHOUT REFERENCE and return the anonymous inner class object.
   
Take an ELC class InterfaceImplementationByUsingAnonymous.
Create the PrinterDemo object and call the print method.
// Step 1: Functional Interface
@FunctionalInterface
interface Printer {
    public abstract void print();
}

// Step 2: Factory Class
class PrinterDemo {
    public Printer getPrinter() {
        // Anonymous inner class WITHOUT reference
        return new Printer() {
            @Override
            public void print() {
                System.out.println("Printing using Anonymous Inner Class implementation!");
            }
        };
    }
}

// Step 3: ELC Class
public class InterfaceImplementationByUsingAnonymous {
    public static void main(String[] args) {
        PrinterDemo demo = new PrinterDemo();
        Printer printer = demo.getPrinter();
        printer.print();
    }
}
