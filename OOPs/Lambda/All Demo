package com.sub.lamda_expression;
@FunctionalInterface
interface Callable
{
	void call();
	
}
public class LambdaDemo5 {

	public static void main(String[] args) {
		getFunctionalInterface(()->IO.println("calling"));

	}
	public static void getFunctionalInterface(Callable c1)
	{
		c1.call();
	}

}
