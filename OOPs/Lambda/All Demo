package com.sub.lamda_expression;
interface Vechile
{
	void run();
}
public class LambdaDemo1 {

	public static void main(String[] args) {
		Vechile car=()->IO.println("Car is running");
		car.run();
		Vechile bus=()->IO.println("Bus is running");
		bus.run();
		Vechile bike=()->IO.println("Bike is running");
		bike.run();

	}

}
package com.sub.lamda_expression;
@FunctionalInterface
interface Calculator
{
	void doSum(int x,int y);
}
public class LambdaDemo2 {

	public static void main(String[] args) {
		Calculator calc=(c,d)->IO.println("Sum is: "+(c+d));
		calc.doSum(10, 20);

	}

}
package com.sub.lamda_expression;
@FunctionalInterface
interface Length
{
	int getLength(String str);
}
public class LambdaDemo3 {

	public static void main(String[] args) {
		Length length=str->
		{
			return str.length();
		};
		
		String name=IO.readln("Enter Your name: ");
        IO.println(length.getLength(name));
	}

}
