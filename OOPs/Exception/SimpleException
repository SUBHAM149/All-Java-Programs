package com.sub.exception_propagation;
import java.util.Scanner;
import java.util.InputMismatchException;;
public class SimpleException {

	public static void main(String[] args) {
		Scanner sc=new Scanner(System.in);
		
      try
      {
    	  IO.println("Enter the first Integer(a): ");
    	  int a=sc.nextInt();
    	  IO.println("Enter the Second Integer(b): ");
    	  int b=sc.nextInt();
    	  IO.println("You Entered a= "+a+" And b= "+b+".");
      }catch(InputMismatchException e){
       IO.println("getMessage():=> " + e.getMessage());
       IO.println("toString():=>"+e.toString());
       IO.println("println():=> InputMismatchException occurred. Please enter only integer numbers.");
       IO.println("printStackTrace():=>");
       e.printStackTrace();

      }finally {
    	  sc.close();
      }
	}

}
