package com.sub.collection_retrieval;

import java.util.Enumeration;
import java.util.Iterator;
import java.util.ListIterator;
import java.util.Spliterator;
import java.util.Vector;

public class PossibleWaysToRetriveCollectionObject {

    public static void main(String[] args) {

        Vector<String> listOfCity = new Vector<>();
        listOfCity.add("Hyderabad");
        listOfCity.add("Kolkata");
        listOfCity.add("Pune");
        listOfCity.add("Indore");
        listOfCity.add("Mumbai");

        IO.println("1) By Using toString() method : ");
        IO.println(listOfCity.toString());

        IO.println("\n2) By Using Ordinary for loop : ");
        for (int i = 0; i < listOfCity.size(); i++) {
            IO.println(listOfCity.get(i));
        }
        
        
        IO.println("\n3) By Using for loop : ");
        for(String city : listOfCity)
        {
        	IO.println(city);
        }
        
        IO.println("\n4) By Using Enumaration interface : ");        
        Enumeration<String> ele=listOfCity.elements();
        while(ele.hasMoreElements())
        {
        	IO.println(ele.nextElement());
        }
        
        IO.println("\n5) By Using Enumaration interface : ");
        Iterator<String> itr=listOfCity.iterator();
        itr.forEachRemaining(city->IO.println(city));
        
        IO.println("\n6) By Using ListIterator interface : ");
        ListIterator<String> listItr=listOfCity.listIterator();
        
        while(listItr.hasNext())
        {
        	IO.println(listItr.next());
        }
        
        IO.println("\nIN BACKWARD DIRECTION");
        
        while(listItr.hasPrevious())
        {
        	IO.println(listItr.previous());
        }
        
        
        IO.println("\n7) By Using Spliteratror interface : ");
        Spliterator<String> splItr=listOfCity.spliterator();
        splItr.forEachRemaining(city->IO.println(city));
        
        
        IO.println("\n8) By Using forEach() Method : ");
        listOfCity.forEach(city->IO.println(city));
        
        
        IO.println("\n9) By Using Method Reference : ");
        listOfCity.forEach(IO::println);
        
        IO.println("\n10) By Using Stream(): ");
        listOfCity.stream().forEach(IO::println);
        
        IO.println("\n11) By Using ParallelStream(): ");
        listOfCity.parallelStream().forEach(IO::println);
        
        
    }
}


